# --- База данных ---
# Для разработки можно использовать SQLite (см. prisma/schema.prisma — закомментирован вариант)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/psych?schema=public"

# --- Сессии / JWT ---
AUTH_SECRET="change-me-to-a-long-random-string-32-bytes-min"
AUTH_COOKIE_NAME="psych_session"
SESSION_TTL_HOURS=24

# --- Шифрование приватных заметок (32 байта в hex или base64) ---
NOTES_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# --- SMS-провайдер КР (пример) ---
SMS_PROVIDER_URL="https://smsapi.example.kg/send"
SMS_PROVIDER_TOKEN=""
SMS_SENDER_NAME="PsychKG"

# --- E-mail (SMTP) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@psych.kg"

# --- Видеосвязь (Daily.co — пример) ---
DAILY_API_KEY=""
DAILY_DOMAIN=""

# --- Платёжный провайдер (Freedom Pay / PayBox КР) ---
FREEDOMPAY_MERCHANT_ID=""
FREEDOMPAY_SECRET_KEY=""
FREEDOMPAY_API_URL="https://api.freedompay.kg"
FREEDOMPAY_RESULT_URL="https://psych.kg/api/payments/webhook"

# --- Хранилище файлов (S3-совместимое) ---
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="psych-media"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# --- Cron (напоминания) ---
CRON_SECRET="change-me-for-production-cron"

# --- Прочее ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DEFAULT_COMMISSION_PERCENT=20
NO_SHOW_HOLD_PERCENT=50
